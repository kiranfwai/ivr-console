# --- Required ---
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=+918031340818

# Generated once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bcrypt-style or plain string. Comparing in constant time on login.
ADMIN_PASSWORD=ivr2026

# Upstash Redis (free tier is fine). Create at console.upstash.com, copy REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Optional ---
# Default press-1 webhook (used when a campaign has no webhook set)
PABBLY_WEBHOOK_URL=

# Alternate "call-shaped" webhook used by the WhatsApp tab's "fire call payload" button
PABBLY_WEBHOOK_URL_CALL=

# Self URL. Leave blank on Vercel — VERCEL_URL is auto-detected.
PUBLIC_BASE_URL=

# Vercel Blob token for in-dashboard audio uploads. If unset, the Audios tab
# falls back to "paste a URL" only.
BLOB_READ_WRITE_TOKEN=

# Set to "1" to require valid Plivo X-Plivo-Signature-V3 on /api/answer, /api/dtmf, /api/hangup.
# Leave unset during initial deploy; flip on after confirming end-to-end works.
VERIFY_PLIVO_SIG=

# --- Dialing rate / concurrency (CPS model) ---
# Account-wide calls-per-second cap. EVERY outbound placeCall (bulk, test, and
# /api/trigger-call) shares one token bucket at this rate. Set to your Plivo
# account's CPS limit. Default 125.
PLIVO_CPS=125
# Max burst the bucket may queue ahead (defaults to PLIVO_CPS = one second's worth).
PLIVO_CPS_BURST=
# Hard ceiling on a job's live-call cap, regardless of the job's concurrency slider.
PLIVO_MAX_LIVE=500
# A "live" row older than this (seconds) is assumed to have lost its hangup
# callback and stops counting against the live cap. Default 180.
PLIVO_MAX_CALL_SEC=180
